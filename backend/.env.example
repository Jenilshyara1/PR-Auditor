# --- GitHub App: backend -> GitHub (installation tokens) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app-private-key.pem
GITHUB_WEBHOOK_SECRET=

# --- GitHub OAuth: user -> dashboard login ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- JWT (dashboard access/refresh tokens) ---
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pr_auditor

# --- Redis (Celery broker/result backend, token cache, dedupe keys) ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- LLM provider (model routing across planner/specialists/critic) ---
OPENAI_API_KEY=

# --- Langfuse (observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=info
